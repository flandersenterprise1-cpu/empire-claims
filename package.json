    "bcryptjs": "^2.4.3",
    "cookie": "^0.6.0",
    "cross-env": "^7.0.3",
    "drizzle-orm": "^0.38.3",
    "express": "^4.21.2",
    "framer-motion": "^11.18.2",
    "jose": "^5.9.6",

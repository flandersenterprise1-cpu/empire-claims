# ─────────────────────────────────────────────────────────────
# Empire Claims Group — environment configuration
# Copy this file to `.env` and fill in the values.
# ─────────────────────────────────────────────────────────────

# Port the server listens on (optional, defaults to 3000)
PORT=3000

# Secret used to sign admin session cookies (JWTs).
# Generate a strong random value, e.g.:  openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-string

# MySQL connection string for the claims database.
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
# Leave empty to run the public website without the CRM database.
DATABASE_URL=mysql://empire:empire@localhost:3306/empire_claims

# Where uploaded claim documents/photos are stored (optional, defaults to ./uploads)
UPLOAD_DIR=./uploads
